# Discord bot（必填）。值請填你自己的 Discord application 設定。
DISCORD_BOT_TOKEN=your-bot-token
DISCORD_PUBLIC_KEY=your-app-public-key
DISCORD_APPLICATION_ID=your-application-id

# 學生帳密走 config.yaml；若只有單一帳號、想用環境變數覆寫可選填：
# TRON_USER=
# TRON_PASS=

# 教師帳號（QR 自動輔助，選用；也可寫在 config.yaml 的 teacher 區塊）：
# TRON_TEACHER_USER=
# TRON_TEACHER_PASS=

# LINE（選用，若也要 LINE 通知/控制）：
# LINE_CHANNEL_ACCESS_TOKEN=
# LINE_CHANNEL_SECRET=
